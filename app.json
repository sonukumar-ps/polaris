{
  "expo": {
    "name": "Polaris",
    "slug": "polaris",
    "scheme": "polaris",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polaris.tradejournal"
    },
    "android": {
      "package": "com.polaris.tradejournal"
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
